:root {
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color: #0f172a;
  background: #eef2f7;
}
* { box-sizing: border-box; }
body { margin: 0; }
button, input, select { font: inherit; }
.app-shell {
  min-height: 100vh;
  padding: 24px;
  background: radial-gradient(circle at top left, rgba(14,165,233,.20), transparent 32rem), linear-gradient(135deg,#eef2f7 0%,#f8fafc 60%,#e0f2fe 100%);
}
.hero {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 20px;
  align-items: stretch;
  padding: 28px;
  border-radius: 28px;
  color: white;
  background: linear-gradient(135deg,#0f172a 0%,#1d4ed8 55%,#0e7490 100%);
  box-shadow: 0 20px 48px rgba(15,23,42,.18);
}
.eyebrow { margin: 0 0 10px; text-transform: uppercase; letter-spacing: .16em; font-size: 12px; opacity: .82; }
.hero h1 { margin: 0; font-size: clamp(30px,4vw,52px); line-height: 1.04; }
.hero-text { max-width: 860px; margin: 14px 0 0; color: #dbeafe; font-size: 16px; }
.page-nav { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 22px; }
.page-nav button { border: 1px solid rgba(255,255,255,.24); background: rgba(255,255,255,.12); color: #e0f2fe; padding: 10px 14px; border-radius: 999px; cursor: pointer; font-weight: 800; }
.page-nav button.nav-active { background: white; color: #1d4ed8; }
.status-box { display: flex; flex-direction: column; justify-content: center; gap: 6px; padding: 20px; border-radius: 22px; background: rgba(255,255,255,.13); border: 1px solid rgba(255,255,255,.24); backdrop-filter: blur(12px); }
.status-box span, .status-box small { color: #dbeafe; }
.status-box strong { font-size: 24px; line-height: 1.1; }
.layout { display: grid; grid-template-columns: minmax(360px,470px) 1fr; gap: 22px; margin-top: 22px; align-items: start; }
.panel, .summary-card { background: rgba(255,255,255,.94); border: 1px solid #e2e8f0; border-radius: 24px; box-shadow: 0 14px 32px rgba(15,23,42,.07); }
.input-panel { position: sticky; top: 18px; padding: 18px; max-height: calc(100vh - 36px); overflow: auto; }
.panel-title { margin-bottom: 14px; }
.panel-title.horizontal { display: flex; justify-content: space-between; align-items: center; gap: 18px; }
.panel-title h2, .table-card h2 { margin: 0; font-size: 20px; }
.panel-title p, .note { margin: 6px 0 0; color: #64748b; font-size: 13px; }
.tabs { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
.tab { border: 0; border-radius: 999px; background: #e2e8f0; color: #334155; padding: 9px 12px; cursor: pointer; font-size: 13px; font-weight: 700; }
.tab.active { background: #1d4ed8; color: white; }
.form-grid { display: grid; grid-template-columns: 1fr; gap: 12px; }
.field { display: block; padding: 12px; border-radius: 16px; background: #f8fafc; border: 1px solid #e2e8f0; }
.field span { display: block; margin-bottom: 8px; font-weight: 750; color: #1e293b; }
.input-row { display: grid; grid-template-columns: 1fr 70px; gap: 8px; align-items: center; }
.input-row input, .input-row select { width: 100%; padding: 10px 11px; border-radius: 12px; border: 1px solid #cbd5e1; background: white; }
.input-row em { font-style: normal; color: #64748b; font-size: 12px; }
.field small { display: block; margin-top: 6px; color: #64748b; line-height: 1.4; }
.action-row { display: flex; flex-wrap: wrap; gap: 10px; }
.sticky-actions { position: sticky; bottom: -18px; padding: 14px 0 0; background: linear-gradient(to top, white 72%, rgba(255,255,255,0)); }
button.primary, button.secondary { border: 0; border-radius: 14px; padding: 12px 16px; cursor: pointer; font-weight: 800; }
button.primary { background: linear-gradient(135deg,#2563eb,#0891b2); color: white; box-shadow: 0 12px 24px rgba(37,99,235,.22); }
button.secondary { background: #e2e8f0; color: #0f172a; }
button:disabled { opacity: .55; cursor: not-allowed; }
.results-area { display: grid; gap: 18px; }
.summary-grid { display: grid; grid-template-columns: repeat(4,minmax(150px,1fr)); gap: 14px; }
.summary-card { padding: 18px; }
.summary-card span { display: block; color: #64748b; font-size: 13px; }
.summary-card strong { display: block; margin-top: 8px; font-size: 30px; line-height: 1; color: #0f172a; }
.summary-card small { display: block; margin-top: 8px; color: #2563eb; font-weight: 800; }
.chart-panel, .table-card, .coil-panel { padding: 18px; }
.charts { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }
.chart-card { border-radius: 18px; border: 1px solid #e2e8f0; background: #f8fafc; padding: 12px; overflow: hidden; }
.chart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.chart-header h3 { margin: 0; font-size: 14px; }
.chart-header span { color: #2563eb; font-size: 12px; font-weight: 800; }
svg { width: 100%; height: auto; background: white; border-radius: 14px; }
svg line { stroke: #cbd5e1; stroke-width: 1.2; }
svg polyline { fill: none; stroke: #2563eb; stroke-width: 4; stroke-linecap: round; stroke-linejoin: round; }
svg text { fill: #64748b; font-size: 13px; }
.empty-state { padding: 36px; text-align: center; border-radius: 18px; color: #64748b; background: #f8fafc; border: 1px dashed #cbd5e1; }
.coil-meta { display: grid; gap: 4px; text-align: right; color: #64748b; font-size: 12px; }
.coil-meta strong { color: #1d4ed8; font-size: 16px; }
.coil-grid { display: grid; grid-template-columns: repeat(3,minmax(220px,1fr)); gap: 14px; }
.coil-card { display: grid; grid-template-columns: 150px 1fr; gap: 14px; align-items: center; padding: 14px; border-radius: 18px; border: 1px solid #e2e8f0; background: #f8fafc; }
.donut-wrap { display: grid; place-items: center; }
.donut { width: 138px; height: 138px; border-radius: 999px; position: relative; box-shadow: inset 0 0 0 1px rgba(15,23,42,.1); }
.donut-hole { position: absolute; inset: 30px; border-radius: 999px; background: white; display: grid; place-items: center; text-align: center; box-shadow: 0 0 0 1px #e2e8f0; }
.donut-hole strong { font-size: 15px; }
.donut-hole span { margin-top: -16px; color: #64748b; font-size: 12px; }
.coil-legend { display: grid; gap: 8px; }
.legend-row { display: grid; grid-template-columns: 12px 42px 70px 1fr; gap: 8px; align-items: center; font-size: 13px; }
.legend-dot { width: 10px; height: 10px; border-radius: 999px; }
.legend-row em { font-style: normal; font-weight: 800; color: #0f172a; }
.legend-row small { color: #64748b; }
.tables-grid { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 18px; }
.table-scroll { overflow: auto; max-height: 420px; margin-top: 12px; border-radius: 16px; border: 1px solid #e2e8f0; }
table { border-collapse: collapse; width: 100%; font-size: 12px; background: white; }
th { position: sticky; top: 0; background: #f1f5f9; color: #334155; text-align: left; font-weight: 800; }
th, td { padding: 10px 12px; border-bottom: 1px solid #e2e8f0; white-space: nowrap; }
.single-page { margin-top: 22px; }
.visual-panel { padding: 20px; }
.badge { display: inline-flex; align-items: center; justify-content: center; padding: 10px 14px; border-radius: 999px; background: #e0f2fe; color: #0369a1; font-size: 13px; font-weight: 900; }
.visual-grid { display: grid; grid-template-columns: minmax(520px,1fr) 360px; gap: 16px; align-items: stretch; }
.system-card, .ph-chart-wrap, .realtime-panel, .ph-state-panel { border: 1px solid #e2e8f0; background: #f8fafc; border-radius: 22px; padding: 14px; }
.system-svg, .ph-svg { display: block; min-height: 460px; background: #ffffff; }
.svg-bg { fill: #f8fafc; stroke: #e2e8f0; }
.system-title { fill: #0f172a; font-size: 20px; font-weight: 900; }
.state-label { fill: #0f172a; font-size: 14px; font-weight: 900; }
.comp-label { fill: #0f172a; font-size: 12px; font-weight: 900; letter-spacing: .05em; }
.component-caption, .small-svg { fill: #475569; font-size: 12px; font-weight: 800; }
.zone-text { fill: white; font-size: 11px; font-weight: 900; }
.flow-dash { animation: dashMove 1.2s linear infinite; }
@keyframes dashMove { to { stroke-dashoffset: -44; } }
.realtime-panel h3, .ph-state-panel h3 { margin: 0 0 12px; font-size: 18px; }
.metric-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 10px; }
.mini-card { border-radius: 16px; border: 1px solid #e2e8f0; background: white; padding: 12px; }
.mini-card span { display:block; color:#64748b; font-size:12px; }
.mini-card strong { display:block; margin-top:5px; font-size:20px; color:#0f172a; }
.mini-card em { font-style:normal; color:#2563eb; font-size:12px; font-weight:800; }
.zone-mini { display:grid; gap:12px; margin-top:14px; }
.zone-bars { border-radius:16px; border:1px solid #e2e8f0; background:#fff; padding:12px; }
.zone-bars > strong { display:block; margin-bottom:8px; }
.zone-bar { display:grid; grid-template-columns:42px 1fr 52px; gap:8px; align-items:center; margin:6px 0; font-size:12px; }
.zone-bar div { height:9px; background:#e2e8f0; border-radius:999px; overflow:hidden; }
.zone-bar i { display:block; height:100%; border-radius:999px; }
.zone-bar em { font-style:normal; color:#475569; text-align:right; }
.timeline-control { display: grid; grid-template-columns: 180px 1fr auto; align-items: center; gap: 16px; margin-top: 16px; padding: 14px; border: 1px solid #e2e8f0; border-radius: 18px; background: #f8fafc; }
.timeline-control span { display:block; color:#64748b; font-size:12px; }
.timeline-control strong { font-size:24px; color:#1d4ed8; }
.timeline-control input[type=range] { width: 100%; accent-color: #2563eb; }
.timeline-buttons { display:flex; gap:8px; flex-wrap:wrap; }
.speed { border:1px solid #cbd5e1; background:white; padding:10px 11px; border-radius:12px; cursor:pointer; font-weight:800; }
.active-speed { background:#dbeafe; border-color:#2563eb; color:#1d4ed8; }
.need-run { padding: 34px; text-align: center; display: grid; gap: 12px; place-items: center; }
.need-run p { max-width: 560px; color:#64748b; margin:0; }
.ph-layout { display:grid; grid-template-columns: minmax(560px,1fr) 430px; gap:16px; }
.ph-svg { min-height: 520px; }
.dome-line { fill:none; stroke-width:3; stroke-linecap:round; }
.dome-line.liquid { stroke:#38bdf8; }
.dome-line.vapor { stroke:#0f766e; }
.cycle-line { fill:none; stroke:#1d4ed8; stroke-width:4; stroke-linejoin:round; stroke-linecap:round; }
.point-label { fill:#0f172a; font-size:16px; font-weight:900; }
.point-small { fill:#475569; font-size:11px; font-weight:800; }
.axis-text { fill:#64748b; font-size:12px; }
.axis-title { fill:#334155; font-size:14px; font-weight:900; }
.ph-state-panel p { color:#64748b; margin:0 0 12px; font-size:13px; }
.ph-state-panel table { font-size:12px; border:1px solid #e2e8f0; border-radius:16px; overflow:hidden; }
.ph-state-panel th, .ph-state-panel td { white-space: normal; }
@media (max-width: 1180px) { .layout, .hero, .visual-grid, .ph-layout { grid-template-columns: 1fr; } .input-panel { position: static; max-height: none; } .charts, .summary-grid, .coil-grid, .tables-grid { grid-template-columns: 1fr; } .timeline-control { grid-template-columns: 1fr; } }

/* V7 professional visual refinements */
.professional-system .system-svg { min-height: 560px; }
.pipe-layer text { paint-order: stroke; stroke: white; stroke-width: 2px; }
.dome-fill { fill: rgba(14, 165, 233, .06); stroke: none; }
.ph-chart-wrap .point-label { font-size: 15px; font-weight: 950; fill: #0f172a; }
.ph-chart-wrap .point-small { font-size: 11px; font-weight: 800; fill: #475569; }
.ph-state-panel td:first-child strong { display:inline-grid; place-items:center; min-width:28px; height:28px; border-radius:999px; color:white; background:#2563eb; }

/* V8 clean professional visualization */
.visual-v8-panel { background: rgba(255,255,255,.97); }
.visual-grid-v8 { grid-template-columns: minmax(720px,1fr) 430px; align-items: stretch; }
.system-card-v8 { padding: 10px; background: #ffffff; }
.professional-system .system-svg { min-height: 610px; }
.pipe-layer text { paint-order: stroke; stroke: white; stroke-width: 2.5px; }
.pipe-layer .flow-dash { animation: dashMove 1.1s linear infinite; }
.realtime-v8 { background: #ffffff; }
.donut-zone-panel { margin-top: 16px; border: 1px solid #e2e8f0; border-radius: 18px; background: #f8fafc; padding: 14px; }
.zone-panel-title { display: flex; justify-content: space-between; gap: 10px; align-items: baseline; margin-bottom: 12px; }
.zone-panel-title strong { font-size: 15px; color: #0f172a; }
.zone-panel-title small { color: #64748b; font-size: 11px; }
.donut-zone-grid { display: grid; grid-template-columns: 1fr; gap: 12px; }
.zone-donut-card { display: grid; grid-template-columns: 112px 1fr; align-items: center; gap: 14px; border: 1px solid #e2e8f0; background: white; border-radius: 16px; padding: 12px; }
.mini-donut { width: 104px; height: 104px; border-radius: 999px; position: relative; box-shadow: inset 0 0 0 1px rgba(15,23,42,.08); }
.mini-donut > div { position: absolute; inset: 25px; border-radius: 999px; background: white; display: grid; place-items: center; text-align: center; box-shadow: 0 0 0 1px #e2e8f0; }
.mini-donut strong { color: #0f172a; font-size: 12px; line-height: 1; }
.mini-donut span { color: #64748b; font-size: 10px; margin-top: -18px; }
.mini-donut-legend { display: grid; gap: 6px; }
.mini-donut-legend span { display: flex; align-items: center; gap: 7px; color: #334155; font-size: 12px; font-weight: 750; }
.mini-donut-legend i { width: 10px; height: 10px; border-radius: 999px; display: inline-block; }
.visual-trends { margin-top: 16px; border: 1px solid #e2e8f0; border-radius: 22px; background: #f8fafc; padding: 14px; }
.section-mini-title { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; margin-bottom: 12px; }
.section-mini-title strong { color: #0f172a; font-size: 17px; }
.section-mini-title span { color: #64748b; font-size: 12px; }
.visual-trend-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 12px; }
.multi-chart svg polyline { stroke-linecap: round; stroke-linejoin: round; }
.mini-legend { display: flex; flex-wrap: wrap; gap: 8px 12px; margin-top: 8px; color: #475569; font-size: 11px; }
.mini-legend span { display: inline-flex; align-items: center; gap: 5px; }
.mini-legend i { width: 10px; height: 3px; border-radius: 999px; display: inline-block; }
@media (max-width: 1280px) { .visual-grid-v8 { grid-template-columns: 1fr; } .donut-zone-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 980px) { .visual-trend-grid, .donut-zone-grid { grid-template-columns: 1fr; } }

/* V9 compact professional visual system */
.visual-v9-panel { background: rgba(255,255,255,.98); padding: 18px; }
.visual-head-v9 { margin-bottom: 8px; }
.visual-grid-v9 { display: grid; grid-template-columns: minmax(760px, 1fr) 430px; gap: 14px; align-items: stretch; }
.system-card-v9 { padding: 8px; background: #ffffff; min-height: 0; }
.professional-system .system-svg-v9 { min-height: 500px; }
.system-svg-v9 { background: #fff; }
.pipe-v9 text { paint-order: stroke; stroke: white; stroke-width: 2.3px; }
.state-label-v9 { font-size: 12px; font-weight: 900; fill: #0f172a; }
.realtime-v9 { background: #ffffff; padding: 14px; }
.realtime-header { display:flex; justify-content: space-between; align-items: baseline; margin-bottom: 10px; }
.realtime-header h3 { margin:0; }
.realtime-header span { color:#2563eb; font-size:12px; font-weight:900; }
.metric-grid-v9 { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; }
.mini-card-v9 { padding: 10px; border-radius: 13px; }
.mini-card-v9 strong { font-size: 18px; }
.donut-v9-panel { margin-top: 12px; padding: 12px; }
.donut-zone-grid-v9 { display: grid; grid-template-columns: 1fr; gap: 9px; }
.zone-donut-card-v9 { grid-template-columns: 92px 1fr; padding: 9px; gap: 10px; border-radius: 14px; }
.zone-donut-card-v9 .mini-donut { width: 86px; height: 86px; }
.zone-donut-card-v9 .mini-donut > div { inset: 22px; }
.zone-donut-card-v9 .mini-donut strong { font-size: 11px; }
.zone-donut-card-v9 .mini-donut span { display:none; }
.mini-donut-legend-v9 { gap: 4px; }
.mini-donut-legend-v9 span { font-size: 11px; }
.mini-donut-legend-v9 b { min-width: 28px; }
.visual-trends-v9 { margin-top: 14px; padding: 12px; }
.visual-trend-grid-v9 { grid-template-columns: repeat(4, minmax(0,1fr)); gap: 10px; }
.chart-card-v9 { padding: 10px; border-radius: 16px; }
.chart-card-v9 svg { min-height: 190px; }
.chart-card-v9 .active-time-line { stroke:#ef4444; stroke-width:1.8; stroke-dasharray:5 5; opacity:.75; }
.chart-card-v9 .active-dot { fill:#ef4444; stroke:#fff; stroke-width:2.5; }
.chart-card-v9 .chart-header h3 { font-size:13px; }
.chart-card-v9 .chart-header span { color:#1d4ed8; font-size:11px; }
@media (max-width: 1380px) { .visual-grid-v9 { grid-template-columns: 1fr; } .donut-zone-grid-v9 { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 1180px) { .visual-trend-grid-v9 { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 820px) { .visual-trend-grid-v9, .donut-zone-grid-v9 { grid-template-columns: 1fr; } }

/* V10 final visual layout fixes */
.visual-layout-v10 {
  display: grid;
  grid-template-columns: minmax(780px, 1fr) 420px;
  gap: 14px;
  align-items: start;
  margin-top: 12px;
}
.visual-left-v10 {
  display: grid;
  gap: 12px;
  align-content: start;
}
.system-card-v10 {
  align-self: start;
  padding: 8px;
}
.professional-system .system-svg-v10 {
  min-height: 0;
  height: clamp(420px, 34vw, 520px);
  display: block;
}
.system-svg-v10 .small-svg {
  font-size: 11px;
}
.visual-trends-v9 {
  margin-top: 0;
}
.visual-trend-grid-v9 {
  align-items: stretch;
}
.chart-card-v9 {
  background: #ffffff;
}
.chart-card-v9 svg {
  min-height: 170px;
  background: #fff;
}
.mini-legend {
  font-size: 10.5px;
  line-height: 1.25;
}
.mini-legend span {
  max-width: 150px;
}
.realtime-v9 {
  align-self: start;
}
.zone-donut-card-v9 {
  min-height: 104px;
}
.pipe-v9 path {
  vector-effect: non-scaling-stroke;
}
@media (max-width: 1380px) {
  .visual-layout-v10 { grid-template-columns: 1fr; }
  .realtime-v9 { order: 2; }
}
@media (max-width: 1180px) {
  .professional-system .system-svg-v10 { height: auto; }
}
